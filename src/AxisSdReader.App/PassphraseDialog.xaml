<Window x:Class="AxisSdReader.App.PassphraseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Encrypted SD card" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SizeToContent="Height" Width="440" ShowInTaskbar="False">
    <Border Background="#16181C" BorderBrush="#2A2F37" BorderThickness="1" CornerRadius="12">
        <StackPanel Margin="26,24,26,22">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Border Width="38" Height="38" CornerRadius="9" Background="#20263B" Margin="0,0,13,0">
                    <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#7FA9FF"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="This SD card is encrypted" FontSize="15" FontWeight="SemiBold" Foreground="#E6E9EE" />
                    <TextBlock x:Name="SubtitleText" FontSize="12" Foreground="#9AA3AD" />
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Enter the camera's SD card encryption passphrase to unlock and read it. The card is never modified."
                       FontSize="12.5" Foreground="#9AA3AD" TextWrapping="Wrap" Margin="0,0,0,14" />

            <Border Background="#1E2228" BorderBrush="#2E343D" BorderThickness="1" CornerRadius="8" Padding="10,2">
                <PasswordBox x:Name="PasswordInput" Background="Transparent" BorderThickness="0" Foreground="#E6E9EE"
                             FontSize="14" Height="30" VerticalContentAlignment="Center" CaretBrush="#7FA9FF" />
            </Border>

            <TextBlock x:Name="ErrorText" FontSize="12" Foreground="#EF6A6A" Margin="2,9,0,0"
                       Visibility="Collapsed" TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button x:Name="CancelButton" Content="Cancel" Width="96" Height="36" Cursor="Hand"
                        IsCancel="True" Click="OnCancel" Margin="0,0,10,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="8" Background="#232830" BorderBrush="#333A44" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="#C7CDD6" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="OkButton" Content="Unlock" Width="112" Height="36" Cursor="Hand"
                        IsDefault="True" Click="OnOk">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="8" Background="#3B82F6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="White" TextElement.FontWeight="SemiBold" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
