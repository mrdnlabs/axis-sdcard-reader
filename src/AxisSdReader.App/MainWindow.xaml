<Window x:Class="AxisSdReader.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:vm="clr-namespace:AxisSdReader.App.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="Axis SD Card Reader" Height="760" Width="1240" MinHeight="560" MinWidth="900"
        Background="#1E1E24">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Background" Value="#33353F" />
            <Setter Property="Foreground" Value="#EAEAEA" />
            <Setter Property="BorderBrush" Value="#4A4D5A" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAEAEA" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EAEAEA" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <!-- Dark-themed ComboBox: WPF's default light chrome looks disabled ("greyed out")
             against the dark window, so the face and popup are templated explicitly. -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#EAEAEA" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="10,6">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D4152" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#EAEAEA" />
            <Setter Property="Background" Value="#33353F" />
            <Setter Property="BorderBrush" Value="#4A4D5A" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="1" CornerRadius="3">
                                            <Path HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"
                                                  Data="M0,0 L4,4 8,0" Stroke="#9AA0B4" StrokeThickness="1.5" />
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="10,0,26,0" VerticalAlignment="Center" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              TextBlock.Foreground="#EAEAEA" />
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   AllowsTransparency="True" StaysOpen="False">
                                <Border Background="#26272E" BorderBrush="#4A4D5A" BorderThickness="1" CornerRadius="3"
                                        MinWidth="{TemplateBinding ActualWidth}" MaxHeight="320" Margin="0,2,0,0">
                                    <ScrollViewer>
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#26272E" Padding="10,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="Card:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox Width="330" Height="30" ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}"
                              VerticalAlignment="Center" />
                    <Button Content="⟳" ToolTip="Scan for cards again" Command="{Binding RefreshDevicesCommand}" />
                    <Button Content="Open card" Command="{Binding OpenSelectedDeviceCommand}" FontWeight="SemiBold" />
                    <Button Content="Open image…" Command="{Binding OpenImageCommand}" />
                    <Button Content="Close" Command="{Binding CloseCardCommand}"
                            Visibility="{Binding IsCardOpen, Converter={StaticResource BoolToVis}}" />
                    <CheckBox Content="Show all drives" IsChecked="{Binding ShowAllDrives}" Margin="12,0,0,0"
                              ToolTip="Also list disks that don't look like Axis camera cards" />
                    <TextBlock Text="{Binding DeviceScanStatus}" VerticalAlignment="Center" Margin="12,0,0,0"
                               Foreground="#9AA0B4" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding BusyText}" VerticalAlignment="Center"
                           HorizontalAlignment="Right" Foreground="#9AA0B4" />
            </DockPanel>
        </Border>

        <!-- Protection banner -->
        <Border Grid.Row="1" Background="#173D2B" Padding="10,6"
                Visibility="{Binding IsCardOpen, Converter={StaticResource BoolToVis}}"
                ToolTip="{Binding ProtectionDetails}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding StatusBanner}" Foreground="#7BE0A2" FontWeight="SemiBold" />
                <TextBlock Text="{Binding CardDescription, StringFormat='   —   {0}'}" Foreground="#9AA0B4" />
            </StackPanel>
        </Border>

        <!-- Main area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Recordings tree -->
            <Border Grid.Column="0" Background="#26272E" Margin="8" CornerRadius="6" Padding="4">
                <Grid>
                    <TreeView ItemsSource="{Binding Cameras}" Background="Transparent" BorderThickness="0"
                              SelectedItemChanged="OnRecordingSelected" Foreground="#EAEAEA">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="True" />
                                <Setter Property="Foreground" Value="#EAEAEA" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type vm:CameraNode}" ItemsSource="{Binding Recordings}">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Margin="2,4" />
                            </HierarchicalDataTemplate>
                            <DataTemplate DataType="{x:Type vm:RecordingItem}">
                                <StackPanel Margin="2,3">
                                    <TextBlock Text="{Binding DisplayName}" />
                                    <TextBlock Text="{Binding Details}" FontSize="11" Foreground="#9AA0B4" />
                                </StackPanel>
                            </DataTemplate>
                        </TreeView.Resources>
                    </TreeView>

                    <TextBlock Text="Insert a card and choose 'Open card',&#10;or open a card image file."
                               Foreground="#9AA0B4" HorizontalAlignment="Center" VerticalAlignment="Center"
                               TextAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCardOpen}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Player -->
            <Grid Grid.Column="1" Margin="0,8,8,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding Player.Title}" FontWeight="SemiBold" Margin="4,0,4,6" />

                <Border Grid.Row="1" Background="Black" CornerRadius="6">
                    <vlc:VideoView x:Name="VideoView" MediaPlayer="{Binding Player.MediaPlayer}" />
                </Border>

                <Grid Grid.Row="2" Margin="4,8,4,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Slider Grid.Row="0" Minimum="0" Maximum="{Binding Player.SessionLengthSeconds}"
                            Value="{Binding Player.SessionPositionSeconds, Mode=OneWay}"
                            Thumb.DragCompleted="OnSliderDragCompleted"
                            PreviewMouseLeftButtonUp="OnSliderClicked"
                            IsEnabled="{Binding Player.HasRecording}" x:Name="TimelineSlider" />

                    <DockPanel Grid.Row="1" Margin="0,6,0,0">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                            <Button Content="⏯ Play / Pause" Command="{Binding Player.PlayPauseCommand}" />
                            <Button Content="⏹ Stop" Command="{Binding Player.StopCommand}" />
                            <TextBlock Text="Speed:" VerticalAlignment="Center" Margin="12,0,4,0" />
                            <ComboBox Width="70" ItemsSource="{Binding Player.AvailableRates}"
                                      SelectedItem="{Binding Player.PlaybackRate}" />
                            <Button Content="⬇ Export…" Command="{Binding ExportSelectedRecordingCommand}"
                                    Margin="12,0,0,0"
                                    IsEnabled="{Binding Player.HasRecording}"
                                    ToolTip="Copy this recording's MKV files to a local folder" />
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding Player.PositionText}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Consolas" />
                    </DockPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
